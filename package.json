{
  "name": "remote-amt-kvm",
  "version": "1.0.0",
  "description": "Remote AMT KVM - Intel AMT Remote Management Console",
  "main": "main.js",
  "author": "",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "build": {
    "appId": "com.remote-amt-kvm.app",
    "productName": "Remote-AMT-KVM",
    "win": {
      "target": "nsis",
      "icon": "favicon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "server/**/*",
      "public/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-ws": "^5.0.2",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
